# ── Core APIs ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
REPLICATE_API_TOKEN=r8_your_replicate_token

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=EAA_your_instagram_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Bot Server (Render) ───────────────────────────────────────────────────────
BOT_SERVER_URL=https://your-app.onrender.com
BOT_API_SECRET=any_random_secret_string

# ── GitHub ────────────────────────────────────────────────────────────────────
GH_PAT=ghp_your_classic_pat         # needs: repo + gist scopes
GH_REPO=enugalamanideepreddy/finamigo-instagram-agent

# ── Image Hosting ─────────────────────────────────────────────────────────────
IMGBB_API_KEY=your_imgbb_key        # fallback only (catbox.moe is primary)

# ── Email (optional backup) ───────────────────────────────────────────────────
AGENT_EMAIL=your_sender@gmail.com
AGENT_EMAIL_PASSWORD=your_gmail_app_password
APPROVAL_EMAIL=your_email@gmail.com

# ── Instagram Token Refresh ───────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ── Features ──────────────────────────────────────────────────────────────────
FEATURES_URL=https://raw.githubusercontent.com/enugalamanideepreddy/FinAmigo/main/FEATURES.md
