# ── Required: Core APIs ──
GEMINI_API_KEY=your_gemini_api_key
REPLICATE_API_TOKEN=r8_your_replicate_token
INSTAGRAM_ACCESS_TOKEN=EAA_your_instagram_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# ── Required: Email Approval ──
AGENT_EMAIL=your_sender_email@gmail.com
AGENT_EMAIL_PASSWORD=your_gmail_app_password
APPROVAL_EMAIL=your_reviewer_email@gmail.com

# ── Required: Google Form Approval ──
GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?output=csv
GOOGLE_FORM_PREFILL_PARAM=entry.YOUR_ENTRY_ID

# ── Optional ──
FEATURES_URL=https://raw.githubusercontent.com/your_user/your_repo/main/FEATURES.md
